ALL : TGMENU.EXP TGCTRL.COM

TGMENU.EXP : TGMENU.OBJ SELECT.OBJ FRAME.OBJ CUTIL.OBJ TGGUI.OBJ DOSCALL.OBJ TMENUITM.OBJ LIBS.LN MAKEFILE
	386LINK TGMENU.OBJ SELECT.OBJ FRAME.OBJ CUTIL.OBJ TGGUI.OBJ DOSCALL.OBJ TMENUITM.OBJ @LIBS.LN

TGMENU.OBJ : TGMENU.C CUTIL.H DEF.H DOSCALL.H EGBCONST.H EGBDEF.H TGGUI.H TMENUITM.H
	RUN386 -nocrt D:\HC386\BIN\HCD386P TGMENU.C

TGGUI.OBJ : TGGUI.C CUTIL.H DEF.H DOSCALL.H EGBCONST.H EGBDEF.H TGGUI.H TMENUITM.H
	RUN386 -nocrt D:\HC386\BIN\HCD386P TGGUI.C

SELECT.OBJ : SELECT.C CUTIL.H DEF.H DOSCALL.H EGBCONST.H EGBDEF.H TGGUI.H TMENUITM.H
	RUN386 -nocrt D:\HC386\BIN\HCD386P SELECT.C

FRAME.OBJ : FRAME.C CUTIL.H DEF.H DOSCALL.H EGBCONST.H EGBDEF.H TGGUI.H TMENUITM.H
	RUN386 -nocrt D:\HC386\BIN\HCD386P FRAME.C

CUTIL.OBJ : CUTIL.C CUTIL.H DEF.H DOSCALL.H EGBCONST.H EGBDEF.H TGGUI.H TMENUITM.H
	RUN386 -nocrt D:\HC386\BIN\HCD386P CUTIL.C

DOSCALL.OBJ : DOSCALL.C CUTIL.H DEF.H DOSCALL.H EGBCONST.H EGBDEF.H TGGUI.H TMENUITM.H
	RUN386 -nocrt D:\HC386\BIN\HCD386P DOSCALL.C

TMENUITM.OBJ : TMENUITM.C CUTIL.H DEF.H DOSCALL.H EGBCONST.H EGBDEF.H TGGUI.H TMENUITM.H
	RUN386 -nocrt D:\HC386\BIN\HCD386P TMENUITM.C



TGCTRL.COM : TGCTRL.ASM
	386ASM -8086 TGCTRL.ASM
	386LINK -8086 TGCTRL.OBJ
	EXE2BIN TGCTRL.EXE TGCTRL.COM
	DEL TGCTRL.EXE
